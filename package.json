{
  "name": "docview",
  "version": "0.1.0",
  "description": "Local live doc viewer for Claude Code projects",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/starlight": "^0.30.6",
    "astro": "^5.18.2",
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.3",
    "mermaid": "^11.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
