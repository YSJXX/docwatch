---
import { getEntry, render } from 'astro:content';
import Mermaid from '@/components/Mermaid.astro';

export const prerender = false;

const id = Astro.params.id ?? '';

function esc(value: string) {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
}

const entry = await getEntry('docs', id);

if (!entry) {
  return new Response(`<!doctype html><html lang="en"><body>Document not found: ${esc(id)}</body></html>`, {
    status: 404,
    headers: { 'content-type': 'text/html; charset=utf-8' },
  });
}

const { Content } = await render(entry);
const crumb = id.split('/').filter(Boolean);
const crumbLast = crumb.at(-1);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry.data.title ?? crumbLast ?? id}</title>
    <style is:global>
      :root {
        --canvas: #f6f8fa;
        --panel: #fff;
        --line: #d0d7de;
        --line2: #eaeef2;
        --fg: #1f2328;
        --blue: #0969da;
        --green-l: #2da44e;
        --faint: #8c959f;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: #fff;
        color: var(--fg);
        font: 14px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }

      .crumb {
        max-width: 760px;
        padding: 18px 26px 0;
        color: var(--faint);
        font-size: 12px;
        word-break: break-word;
      }

      .crumb b {
        color: var(--fg);
      }

      .doc {
        max-width: 760px;
        padding: 26px 26px 60px;
      }

      .doc h1 {
        font-size: 26px;
        margin: 0 0 6px;
        font-weight: 700;
        letter-spacing: -.3px;
        line-height: 1.25;
      }

      .doc h2 {
        font-size: 19px;
        margin: 26px 0 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--line2);
        line-height: 1.3;
      }

      .doc h3 {
        font-size: 15px;
        margin: 18px 0 8px;
        line-height: 1.35;
      }

      .doc p {
        color: #33383f;
        margin: 10px 0;
      }

      .doc ul {
        margin: 8px 0;
        padding-left: 22px;
      }

      .doc li {
        margin: 5px 0;
        color: #33383f;
      }

      .doc code {
        background: var(--line2);
        border-radius: 4px;
        padding: 1px 5px;
        font-family: "SF Mono", Consolas, "Liberation Mono", monospace;
        font-size: 12px;
      }

      .doc pre {
        overflow: auto;
        margin: 12px 0;
        padding: 12px;
        background: var(--canvas);
        border: 1px solid var(--line2);
        border-radius: 6px;
      }

      .doc pre code {
        display: block;
        padding: 0;
        background: transparent;
        border-radius: 0;
      }

      .doc table {
        border-collapse: collapse;
        width: 100%;
        margin: 12px 0;
        font-size: 13px;
      }

      .doc th,
      .doc td {
        border: 1px solid var(--line);
        padding: 7px 10px;
        text-align: left;
      }

      .doc th {
        background: var(--canvas);
        font-weight: 600;
      }

      .doc input[type="checkbox"] {
        width: 13px;
        height: 13px;
        margin: 0 8px 0 0;
        accent-color: var(--green-l);
        vertical-align: -2px;
      }

      .tasklist {
        list-style: none;
        padding-left: 2px;
      }

      .tasklist li {
        display: flex;
        gap: 8px;
        align-items: baseline;
      }

      .tasklist .cb {
        width: 13px;
        height: 13px;
        border: 1.5px solid var(--blue);
        border-radius: 3px;
        flex: 0 0 auto;
        position: relative;
        top: 2px;
      }

      .tasklist .cb.done {
        background: var(--green-l);
        border-color: var(--green-l);
      }

      .mermaid-rendered {
        margin: 12px 0;
        overflow: auto;
      }
    </style>
  </head>
  <body>
    <div class="crumb" aria-label="Document path">
      {
        crumb.map((part, index) => (
          <>
            {index > 0 && ' / '}
            {index === crumb.length - 1 ? <b>{part}</b> : part}
          </>
        ))
      }
    </div>
    <article class="doc"><Content /></article>
    <Mermaid />
  </body>
</html>
