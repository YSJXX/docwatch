---
import MonitorLayout from '@/layouts/MonitorLayout.astro';
import { getCollection } from 'astro:content';
import { DEFAULT_CONFIG } from '@/data/config';
import { getActivity } from '@/data/activity';
import { resolveCategory } from '@/data/categories';
import { scanCheckboxes, scanGitLog } from '@/data/scan';
import { scanDiff, type DiffLine } from '@/data/diff';
import { buildDocIndex, fileToDocId, targetRepoRoot } from '@/data/paths';
import { scanWatchedFiles } from '@/data/watch-files';
import fs from 'node:fs/promises';
import path from 'node:path';

export const prerender = false;

type Status = 'NEW' | 'MOD' | 'DOC';
type PlanItem = { text: string; done: boolean };
type Detail = {
  name: string;
  dir: string;
  path: string;
  status: Status;
  size: string;
  created: string;
  lines: string;
  excerpt: string;
  plan?: PlanItem[];
  diff?: DiffLine[];
  kind?: 'config';
};
type TimelineItem = { id?: string; name: string; dir: string; status: Status; ago: string; preview: string | null; rel: string; mtime: number };
type TreeNode = { depth: number; isDir: boolean; name: string; preview?: string; status?: Status; kind?: 'doc' | 'config' };

function esc(value: string) {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
}

function mappedStatus(status: string | undefined): Exclude<Status, 'DOC'> | null {
  if (status === '??' || status === 'A' || status === 'C') return 'NEW';
  if (status === 'M' || status === 'R') return 'MOD';
  return null;
}

function humanSize(bytes: number) {
  if (bytes < 1024) return `${bytes} B`;
  return `${(bytes / 1024).toFixed(1)} KB`;
}

function stamp(ms: number) {
  const d = new Date(ms);
  const pad = (n: number) => String(n).padStart(2, '0');
  return `${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function ago(ms: number) {
  const mins = Math.max(0, Math.round((Date.now() - ms) / 60_000));
  if (mins < 1) return '방금 전';
  if (mins < 60) return `${mins}분 전`;
  const hours = Math.round(mins / 60);
  if (hours < 24) return `${hours}시간 전`;
  return `${Math.round(hours / 24)}일 전`;
}

function excerptOf(markdown: string) {
  const text = markdown
    .replace(/\r\n/g, '\n')
    .split(/\n{2,}/)
    .map(block => block.trim())
    .find(block => block && !/^#{1,6}\s/.test(block) && !/^```/.test(block));
  const cleaned = (text ?? '문서 발췌를 찾을 수 없습니다.')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();
  return cleaned.length > 280 ? `${cleaned.slice(0, 277)}...` : cleaned;
}

function parsePlan(markdown: string): PlanItem[] | undefined {
  const items: PlanItem[] = [];
  let inFence = false;
  for (const raw of markdown.replace(/\r\n/g, '\n').split('\n')) {
    if (/^\s*```/.test(raw)) { inFence = !inFence; continue; }
    if (inFence) continue;
    const line = raw.replace(/`[^`\n]*`/g, '');
    const m = /^\s*[-*+]\s+\[([ xX])\]\s+(.*)$/.exec(line);
    if (m) items.push({ done: m[1] !== ' ', text: m[2].trim() });
  }
  return items.length ? items : undefined;
}

function dirOf(rel: string) {
  const dir = path.posix.dirname(rel);
  return dir === '.' ? '' : `${dir}/`;
}

function buildTree(items: Array<{ preview: string; rel: string; name: string; status: Status; kind: 'doc' | 'config' }>): TreeNode[] {
  type Leaf = { preview: string; name: string; status: Status; kind: 'doc' | 'config' };
  type Node = { dirs: Map<string, Node>; files: Leaf[] };
  const root: Node = { dirs: new Map(), files: [] };

  for (const item of items) {
    const parts = item.rel.split('/');
    const file = parts.pop() ?? item.name;
    let node = root;
    for (const part of parts) {
      const next = node.dirs.get(part) ?? { dirs: new Map(), files: [] };
      node.dirs.set(part, next);
      node = next;
    }
    node.files.push({ preview: item.preview, name: file, status: item.status, kind: item.kind });
  }

  const out: TreeNode[] = [];
  const walk = (node: Node, depth: number) => {
    [...node.dirs.entries()].sort(([a], [b]) => a.localeCompare(b)).forEach(([name, child]) => {
      out.push({ depth, isDir: true, name });
      walk(child, depth + 1);
    });
    node.files.sort((a, b) => a.name.localeCompare(b.name)).forEach(file => {
      out.push({ depth, isDir: false, name: file.name, preview: file.preview, status: file.status, kind: file.kind });
    });
  };
  walk(root, 0);
  return out;
}

const root = targetRepoRoot();
const docs = await getCollection('docs');
const activity = await getActivity(root, DEFAULT_CONFIG);
const commits = await scanGitLog(root, 20).catch(() => []);
const docIndex = buildDocIndex(docs);
const sourceRelById = new Map([...docIndex].map(([sourceRelPath, id]) => [id, sourceRelPath]));
const dirtyByRel = new Map<string, Exclude<Status, 'DOC'>>();
let newCount = 0, modCount = 0;

for (const entry of activity.dirty) {
  const status = mappedStatus(entry.status);
  if (!status) continue;
  dirtyByRel.set(entry.path, status);
  if (status === 'NEW') newCount++;
  else modCount++;
}

const details: Record<string, Detail> = {};
const docSources = await Promise.all(docs.map(async entry => {
  const rel = sourceRelById.get(entry.id) ?? entry.id;
  const abs = path.join(root, rel);
  const [content, stat] = await Promise.all([
    fs.readFile(abs, 'utf8').catch(() => ''),
    fs.stat(abs).catch(() => null),
  ]);
  const status = dirtyByRel.get(rel) ?? 'DOC';
  const lines = content ? String(content.replace(/\r\n/g, '\n').split('\n').length) : '0';
  const planStats = scanCheckboxes(content);
  const plan = planStats.total ? parsePlan(content) : undefined;
  const diff = status === 'MOD' ? await scanDiff(root, rel) : [];
  const name = path.posix.basename(rel);
  const dir = dirOf(rel);
  const detail: Detail = {
    name,
    dir,
    path: rel,
    status,
    size: stat ? humanSize(stat.size) : '0 B',
    created: stat ? stamp(stat.mtimeMs) : '—',
    lines,
    excerpt: excerptOf(content),
    ...(plan ? { plan } : {}),
    ...(diff.length ? { diff } : {}),
  };
  details[entry.id] = detail;
  return { id: entry.id, rel, name, dir, status, mtime: stat?.mtimeMs ?? 0, category: resolveCategory(rel, DEFAULT_CONFIG.categories) };
}));

const watched = await scanWatchedFiles(root, DEFAULT_CONFIG);
const watchedDetails = await Promise.all(watched.map(async w => {
  const [content, stat] = await Promise.all([
    fs.readFile(w.abs, 'utf8').catch(() => ''),
    fs.stat(w.abs).catch(() => null),
  ]);
  const status = dirtyByRel.get(w.rel) ?? 'DOC';
  const diff = status === 'MOD' ? await scanDiff(root, w.rel) : [];
  const detail: Detail = {
    name: path.posix.basename(w.rel),
    dir: dirOf(w.rel),
    path: w.rel,
    status,
    size: stat ? humanSize(stat.size) : '0 B',
    created: stat ? stamp(stat.mtimeMs) : '—',
    lines: content ? String(content.replace(/\r\n/g, '\n').split('\n').length) : '0',
    excerpt: '',
    kind: 'config',
    ...(diff.length ? { diff } : {}),
  };
  return { rel: w.rel, name: detail.name, status, preview: `/rawpreview/${w.rel}`, detail };
}));
const watchedByRel = new Map(watchedDetails.map(w => [w.rel, w]));

const timelineByRel = new Map<string, TimelineItem>();
for (const item of activity.recentlyModified) {
  const id = fileToDocId(item.path, docIndex) ?? undefined;
  const detail = id ? details[id] : null;
  timelineByRel.set(item.path, {
    id,
    rel: item.path,
    name: detail?.name ?? path.posix.basename(item.path),
    dir: detail?.dir ?? dirOf(item.path),
    status: (detail?.status ?? dirtyByRel.get(item.path) ?? 'DOC') as Status,
    ago: ago(item.mtime),
    preview: id ? `/preview/${id}` : null,
    mtime: item.mtime,
  });
}
for (const item of activity.dirty) {
  const status = mappedStatus(item.status);
  if (!status) continue;
  const id = fileToDocId(item.path, docIndex) ?? undefined;
  const detail = id ? details[id] : null;
  if (timelineByRel.has(item.path)) {
    const existing = timelineByRel.get(item.path);
    if (existing) existing.status = status;
    continue;
  }
  timelineByRel.set(item.path, {
    id,
    rel: item.path,
    name: detail?.name ?? path.posix.basename(item.path),
    dir: detail?.dir ?? dirOf(item.path),
    status,
    ago: '방금 전',
    preview: id ? `/preview/${id}` : null,
    mtime: Date.now(),
  });
}

const timeline = [...timelineByRel.values()].sort((a, b) => b.mtime - a.mtime).slice(0, 16);
if (!timeline.length && commits[0]) {
  const commit = commits[0];
  for (const file of commit.files.slice(0, 6)) {
    const id = fileToDocId(file, docIndex) ?? undefined;
    const detail = id ? details[id] : null;
    timeline.push({
      id,
      rel: file,
      name: detail?.name ?? path.posix.basename(file),
      dir: detail?.dir ?? dirOf(file),
      status: detail?.status ?? 'DOC',
      ago: commit.relTime,
      preview: id ? `/preview/${id}` : null,
      mtime: 0,
    });
  }
}

for (const t of timeline) { if (!t.preview) t.preview = watchedByRel.get(t.rel)?.preview ?? null; }

const tree = buildTree([
  ...docSources.map(d => ({ preview: `/preview/${d.id}`, rel: d.rel, name: d.name, status: d.status, kind: 'doc' as const })),
  ...watchedDetails.map(w => ({ preview: w.preview, rel: w.rel, name: w.name, status: w.status, kind: 'config' as const })),
]);

const checklists = docSources
  .filter(doc => details[doc.id]?.plan?.length)
  .map(doc => {
    const items = details[doc.id].plan ?? [];
    return { id: doc.id, name: doc.name, dir: doc.dir, items, done: items.filter(i => i.done).length, total: items.length };
  })
  .sort((a, b) => (a.dir + a.name).localeCompare(b.dir + b.name));
const checklistTotal = checklists.reduce((n, c) => n + c.total, 0);
const checklistDone = checklists.reduce((n, c) => n + c.done, 0);

const clientDetails: Record<string, Detail> = {};
for (const [id, d] of Object.entries(details)) clientDetails[`/preview/${id}`] = d;
for (const w of watchedDetails) clientDetails[w.preview] = w.detail;

const docsTotal = docs.length;
void esc;
---
<MonitorLayout repoPath={root} docsTotal={docsTotal} newCount={newCount} modCount={modCount}>
  <section class="monitor-col col-one">
    <div class="section-head">
      <div><span>⚡</span><b>실시간 타임라인</b></div>
      <span class="count" id="timeline-count">{timeline.length}</span>
    </div>
    <div class="timeline-list" id="timeline-list">
      {timeline.length ? timeline.map((item, index) => {
        const attrs = item.preview ? { 'data-preview': item.preview, role: 'button', tabindex: '0' } : {};
        return (
          <div class={`timeline-row ${index === 0 ? 'fresh' : ''} ${item.status.toLowerCase()}`} data-id={item.id} data-rel={item.rel} {...attrs}>
            <div class="row-top">
              <span class="event-dot"></span>
              <span class="row-name">{item.name}</span>
              <span class="status-badge">{item.status}</span>
            </div>
            <div class="row-meta"><span>{item.dir}</span><span>{item.ago}</span></div>
          </div>
        );
      }) : <div class="empty-state compact">최근 활동이 없습니다.</div>}
    </div>

    <div class="section-head tree-head">
      <div><span>🗂️</span><b>프로젝트 파일 트리</b></div>
    </div>
    <div class="tree-list" id="tree-list">
      {tree.map(node => node.isDir ? (
        <div class="tree-row dir" style={`--depth:${node.depth}`}>
          <span class="tree-icon">▸</span>
          <span class="tree-name">{node.name}</span>
        </div>
      ) : (
        <div class={`tree-row file ${(node.status ?? 'DOC').toLowerCase()}`} style={`--depth:${node.depth}`} data-preview={node.preview} role="button" tabindex="0">
          <span class="tree-icon">{node.kind === 'config' ? '⚙' : ''}</span>
          <span class="tree-name">{node.name}</span>
          <span class="status-badge">{node.status}</span>
        </div>
      ))}
    </div>

    <div class="section-head cl-head">
      <div><span>☑</span><b>프로젝트 체크리스트</b></div>
      <span class="count">{checklistDone}/{checklistTotal}</span>
    </div>
    <div class="checklist-list" id="checklist-list">
      {checklists.length ? checklists.map(cl => (
        <div class="cl-group">
          <div class="cl-doc" data-preview={`/preview/${cl.id}`} role="button" tabindex="0" title={cl.dir + cl.name}>
            <span class="cl-doc-name">{cl.name}</span>
            <span class="cl-doc-count">{cl.done}/{cl.total}</span>
          </div>
          {cl.items.map(item => (
            <div class={`cl-item ${item.done ? 'done' : ''}`}>
              <span class="cl-box">{item.done ? '✓' : ''}</span>
              <span class="cl-text">{item.text}</span>
            </div>
          ))}
        </div>
      )) : <div class="empty-state compact">체크리스트가 없습니다.</div>}
    </div>
  </section>

  <section class="monitor-col col-two">
    <div id="detail-pane">
      <div class="empty-state">타임라인·트리에서 파일을 선택하세요</div>
    </div>
  </section>

  <section class="monitor-col col-three">
    <iframe id="doc-frame" title="document preview" hidden></iframe>
    <div id="col3-empty" class="empty-state">문서를 선택하면 여기에 전체 내용이 표시됩니다.</div>
  </section>

  <script id="dw-details" type="application/json" set:html={JSON.stringify(clientDetails).replaceAll('<', '\\u003c').replaceAll('>', '\\u003e').replaceAll('&', '\\u0026')}></script>

  <style is:global>
    .monitor-col { display: flex; flex-direction: column; min-height: 0; min-width: 0; background: var(--md-sys-color-surface-container-low); }
    .col-one { flex: 0 0 23%; border-right: 1px solid var(--md-sys-color-outline-variant); }
    .col-two { flex: 0 0 30%; border-right: 1px solid var(--md-sys-color-outline-variant); background: var(--md-sys-color-surface-container-lowest); }
    .col-three { flex: 1 1 47%; background: var(--md-sys-color-background); position: relative; }
    .section-head { flex: none; display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border-bottom: 1px solid var(--md-sys-color-outline-variant); }
    .section-head > div { display: flex; align-items: center; gap: 8px; min-width: 0; }
    .section-head b { font-size: 10.5px; font-weight: 700; letter-spacing: .6px; text-transform: uppercase; color: var(--md-sys-color-on-surface); }
    .section-head .count { font-family: var(--md-sys-typescale-mono-font); font-size: 11px; padding: 1px 7px; border-radius: 999px; background: var(--md-sys-color-surface-container-highest); color: var(--md-sys-color-on-surface-variant); }
    .tree-head { border-top: 1px solid var(--md-sys-color-outline-variant); }
    .timeline-list { flex: 1 1 30%; min-height: 90px; overflow-y: auto; padding: 6px 8px; display: flex; flex-direction: column; gap: 1px; }
    .tree-list { flex: 1 1 30%; min-height: 90px; overflow-y: auto; padding: 6px 8px; }
    .timeline-row { padding: 5px 9px; border-radius: 5px; border: 1px solid transparent; background: transparent; transition: background .15s, border-color .15s; }
    .timeline-row.fresh { animation: dashSlideIn .55s ease; }
    .row-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
    .event-dot { flex: none; width: 8px; height: 8px; border-radius: 999px; background: var(--md-sys-color-outline); }
    .timeline-row.new .event-dot { background: var(--dw-green-dot); box-shadow: 0 0 0 3px var(--dw-green-glow); }
    .timeline-row.mod .event-dot { background: var(--dw-orange-dot); box-shadow: 0 0 0 3px var(--dw-orange-glow); }
    .row-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--md-sys-typescale-mono-font); font-size: 12px; font-weight: 500; color: var(--md-sys-color-on-surface); }
    .status-badge { flex: none; font-family: var(--md-sys-typescale-mono-font); font-size: 9.5px; font-weight: 500; letter-spacing: .4px; padding: 1px 6px; border-radius: 4px; background: var(--md-sys-color-surface-container-highest); color: var(--md-sys-color-on-surface-variant); }
    .new .status-badge { background: var(--dw-green-bg); color: var(--dw-green); }
    .mod .status-badge { background: var(--dw-orange-bg); color: var(--dw-orange); }
    .row-meta { display: flex; justify-content: space-between; gap: 10px; margin-top: 3px; font-size: 10px; color: var(--md-sys-color-on-surface-variant); min-width: 0; }
    .row-meta span:first-child { font-family: var(--md-sys-typescale-mono-font); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .tree-row { display: flex; align-items: center; gap: 7px; padding: 3px 8px; padding-left: calc(8px + var(--depth) * 15px); border-radius: 6px; min-width: 0; transition: background .12s; }
    .tree-row.dir { cursor: default; }
    .tree-row.file { cursor: pointer; }
    .tree-icon { flex: none; width: 10px; font-size: 10px; color: var(--md-sys-color-on-surface-variant); }
    .tree-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--md-sys-typescale-mono-font); font-size: 12px; }
    .tree-row.dir .tree-name { font-weight: 700; color: var(--md-sys-color-on-surface-variant); }
    [data-preview] { cursor: pointer; }
    [data-preview]:hover, [data-preview]:focus-visible { background: var(--md-sys-color-surface-container-high); outline: none; }
    [data-preview].sel { background: var(--md-sys-color-primary-container); border-color: var(--md-sys-color-primary); color: var(--md-sys-color-on-primary-container); }
    [data-preview].sel .row-name, [data-preview].sel .tree-name { color: var(--md-sys-color-on-primary-container); }
    #detail-pane { flex: 1; min-height: 0; overflow-y: auto; padding: 10px 12px; animation: dashFade .28s ease; }
    .detail-head { flex: none; padding: 8px 12px; margin: -10px -12px 10px; border-bottom: 1px solid var(--md-sys-color-outline-variant); }
    .detail-title { display: flex; align-items: center; gap: 8px; min-width: 0; }
    .detail-name { font-family: var(--md-sys-typescale-mono-font); font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .detail-sub { font-size: 11px; color: var(--md-sys-color-on-surface-variant); margin-top: 3px; }
    .meta-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
    .meta-chip { display: flex; flex-direction: column; gap: 2px; padding: 8px 12px; border-radius: 5px; background: var(--md-sys-color-surface-container-high); font-size: 11px; min-width: 88px; }
    .meta-chip span { color: var(--md-sys-color-on-surface-variant); }
    .meta-chip b { font-family: var(--md-sys-typescale-mono-font); font-weight: 500; }
    .excerpt-label { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: .4px; text-transform: uppercase; color: var(--dw-green); margin-bottom: 10px; }
    .excerpt { border-left: 3px solid var(--dw-green-border); padding: 2px 0 2px 14px; color: var(--md-sys-color-on-surface-variant); font-size: 13.5px; line-height: 1.65; white-space: pre-wrap; }
    .notice { margin-bottom: 12px; padding: 10px 12px; border-radius: 6px; background: var(--dw-orange-bg); color: var(--dw-orange); font-size: 12px; }
    .diff-stat { display: flex; gap: 14px; margin-bottom: 12px; font-size: 11px; font-family: var(--md-sys-typescale-mono-font); }
    .diff-add-count { color: var(--dw-green); }
    .diff-del-count { color: var(--dw-red); }
    .diff-box { border: 1px solid var(--md-sys-color-outline-variant); border-radius: 5px; overflow: hidden; font-family: var(--md-sys-typescale-mono-font); font-size: 12.5px; line-height: 1.7; }
    .diff-line { display: flex; }
    .diff-line.add { background: var(--dw-green-bg); }
    .diff-line.del { background: var(--dw-red-bg); }
    .diff-gutter { flex: none; width: 34px; text-align: right; padding: 1px 8px 1px 0; color: var(--md-sys-color-on-surface-variant); opacity: .6; user-select: none; border-right: 1px solid var(--md-sys-color-outline-variant); }
    .diff-sign { flex: none; width: 20px; text-align: center; }
    .diff-line.add .diff-sign { color: var(--dw-green); }
    .diff-line.del .diff-sign { color: var(--dw-red); }
    .diff-text { white-space: pre-wrap; word-break: break-word; }
    .empty-state { min-height: 100%; display: flex; align-items: center; justify-content: center; padding: 24px; text-align: center; color: var(--md-sys-color-on-surface-variant); font-size: 13px; }
    .empty-state.compact { min-height: 120px; }
    .empty-state[hidden] { display: none; }
    #doc-frame { width: 100%; height: 100%; border: 0; background: #fff; }
    #doc-frame[hidden] { display: none; }
    .cl-head { border-top: 1px solid var(--md-sys-color-outline-variant); }
    .checklist-list { flex: 1 1 40%; min-height: 90px; overflow-y: auto; padding: 6px 8px; }
    .cl-group { margin-bottom: 10px; }
    .cl-doc { display: flex; align-items: center; gap: 8px; padding: 4px 8px; border-radius: 6px; min-width: 0; }
    .cl-doc-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--md-sys-typescale-mono-font); font-size: 11.5px; font-weight: 600; color: var(--md-sys-color-on-surface); }
    .cl-doc-count { flex: none; font-family: var(--md-sys-typescale-mono-font); font-size: 10px; color: var(--md-sys-color-on-surface-variant); }
    .cl-item { display: flex; align-items: flex-start; gap: 7px; padding: 2px 8px 2px 18px; font-size: 11.5px; line-height: 1.45; }
    .cl-box { flex: none; width: 13px; height: 13px; margin-top: 1px; border-radius: 3px; border: 1.5px solid var(--md-sys-color-outline); display: inline-flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 700; color: transparent; }
    .cl-item.done .cl-box { background: var(--dw-green-dot); border-color: var(--dw-green-dot); color: #fff; }
    .cl-text { flex: 1; min-width: 0; color: var(--md-sys-color-on-surface); word-break: break-word; }
    .cl-item.done .cl-text { color: var(--md-sys-color-on-surface-variant); text-decoration: line-through; }
    @media (max-width: 900px) {
      .monitor-col { min-height: 70vh; border-right: 0; border-bottom: 1px solid var(--md-sys-color-outline-variant); }
      .col-one, .col-two, .col-three { flex: none; }
    }
  </style>

  <script>
    const detailsEl = document.getElementById('dw-details');
    const details = detailsEl?.textContent ? JSON.parse(detailsEl.textContent) : {};
    const detailPane = document.getElementById('detail-pane');
    const frame = document.getElementById('doc-frame');
    const col3Empty = document.getElementById('col3-empty');
    const timelineList = document.getElementById('timeline-list');
    const timelineCount = document.getElementById('timeline-count');
    const statNew = document.getElementById('stat-new');
    const statMod = document.getElementById('stat-mod');
    let poll = 0;

    function el(tag, className, text) {
      const node = document.createElement(tag);
      if (className) node.className = className;
      if (text !== undefined) node.textContent = text;
      return node;
    }

    function badge(status) {
      const node = el('span', 'status-badge', status);
      return node;
    }

    function fillDetail(url) {
      const detail = details[url];
      if (!detail || !detailPane) return;
      detailPane.replaceChildren();

      const head = el('div', 'detail-head');
      const title = el('div', 'detail-title');
      title.append(badge(detail.status), el('span', 'detail-name', detail.name));
      head.append(title, el('div', 'detail-sub', detail.dir || detail.path));
      detailPane.append(head);

      if (detail.status === 'NEW' || detail.kind === 'config') {
        const metas = el('div', 'meta-grid');
        [['크기', detail.size], ['생성일', detail.created], ['라인', detail.lines]].forEach(([label, value]) => {
          const chip = el('div', 'meta-chip');
          chip.append(el('span', '', label), el('b', '', value));
          metas.append(chip);
        });
        detailPane.append(metas);
      }

      if (detail.status === 'MOD' && detail.diff && detail.diff.length) {
        const adds = detail.diff.filter(line => line.t === 'add').length;
        const dels = detail.diff.filter(line => line.t === 'del').length;
        const stat = el('div', 'diff-stat');
        stat.append(el('span', 'diff-add-count', `+${adds} 추가`), el('span', 'diff-del-count', `−${dels} 삭제`));
        const box = el('div', 'diff-box');
        detail.diff.forEach((line, i) => {
          const row = el('div', `diff-line ${line.t}`);
          row.append(
            el('span', 'diff-gutter', String(i + 1)),
            el('span', 'diff-sign', line.t === 'add' ? '+' : line.t === 'del' ? '−' : ' '),
            el('span', 'diff-text', line.s),
          );
          box.append(row);
        });
        detailPane.append(stat, box);
      } else if (detail.excerpt) {
        detailPane.append(el('div', 'excerpt-label', '✦ 문서 발췌'), el('div', 'excerpt', detail.excerpt));
      } else if (detail.kind === 'config') {
        detailPane.append(el('div', 'notice', '⚙ 설정·매니페스트 파일 — 오른쪽에서 전체 내용을 확인하세요'));
      }
    }

    function select(url, target) {
      if (!url || !details[url]) return;
      if (!(url.startsWith('/preview/') || url.startsWith('/rawpreview/'))) return;
      document.querySelectorAll('[data-preview].sel').forEach(node => node.classList.remove('sel'));
      if (target instanceof HTMLElement) target.classList.add('sel');
      fillDetail(url);
      if (frame instanceof HTMLIFrameElement && col3Empty) {
        frame.src = url;
        frame.hidden = false;
        col3Empty.hidden = true;
      }
      history.replaceState(null, '', '?doc=' + encodeURIComponent(url));
    }

    function openTarget(target) {
      if (!(target instanceof HTMLElement)) return;
      const url = target.dataset.preview;
      if (url) select(url, target);
    }

    document.addEventListener('click', event => {
      const target = event.target instanceof Element ? event.target.closest('[data-preview]') : null;
      openTarget(target);
    });

    document.addEventListener('keydown', event => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      const target = event.target instanceof Element ? event.target.closest('[data-preview]') : null;
      if (!target) return;
      event.preventDefault();
      target.dispatchEvent(new MouseEvent('click', { bubbles: true }));
    });

    function renderTimeline(items, fresh) {
      if (!timelineList) return;
      timelineList.replaceChildren();
      items.slice(0, 16).forEach((item, index) => {
        const row = el('div', `timeline-row ${(item.status || 'DOC').toLowerCase()} ${fresh && index === 0 ? 'fresh' : ''}`);
        if (item.preview) {
          row.dataset.preview = item.preview;
          row.setAttribute('role', 'button');
          row.tabIndex = 0;
        }
        const top = el('div', 'row-top');
        top.append(el('span', 'event-dot'), el('span', 'row-name', item.name), badge(item.status || 'DOC'));
        const meta = el('div', 'row-meta');
        meta.append(el('span', '', item.dir || ''), el('span', '', item.ago || '방금 전'));
        row.append(top, meta);
        timelineList.append(row);
      });
      if (!items.length) timelineList.append(el('div', 'empty-state compact', '최근 활동이 없습니다.'));
      if (timelineCount) timelineCount.textContent = String(items.length);
    }

    function relDir(rel) {
      const idx = rel.lastIndexOf('/');
      return idx === -1 ? '' : rel.slice(0, idx + 1);
    }

    function statusOf(raw) {
      if (raw === '??' || raw === 'A' || raw === 'C') return 'NEW';
      if (raw === 'M' || raw === 'R') return 'MOD';
      return null;
    }

    function applyActivity(data) {
      let nextNew = 0, nextMod = 0;
      const byRel = new Map();

      (data.recentlyModified || []).forEach(item => {
        const detailEntry = Object.entries(details).find(([, detail]) => detail.path === item.path);
        const url = detailEntry?.[0];
        const detail = detailEntry?.[1];
        byRel.set(item.path, {
          preview: url ?? null,
          name: detail?.name || item.path.split('/').pop() || item.path,
          dir: detail?.dir || relDir(item.path),
          status: detail?.status || 'DOC',
          ago: '방금 전',
          mtime: item.mtime || 0,
        });
      });

      (data.dirty || []).forEach(item => {
        const status = statusOf(item.status);
        if (!status) return;
        if (status === 'NEW') nextNew++;
        else nextMod++;
        const detailEntry = Object.entries(details).find(([, detail]) => detail.path === item.path);
        const url = detailEntry?.[0];
        const detail = detailEntry?.[1];
        const existing = byRel.get(item.path);
        byRel.set(item.path, {
          preview: url ?? null,
          name: detail?.name || item.path.split('/').pop() || item.path,
          dir: detail?.dir || relDir(item.path),
          status,
          ago: existing?.ago || '방금 전',
          mtime: existing?.mtime || Date.now(),
        });
      });

      const items = [...byRel.values()].sort((a, b) => (b.mtime || 0) - (a.mtime || 0)).slice(0, 16);
      renderTimeline(items, true);
      if (statNew) statNew.textContent = String(nextNew);
      if (statMod) statMod.textContent = String(nextMod);
    }

    async function pollLive() {
      try {
        const res = await fetch('/api/activity.json', { cache: 'no-store' });
        if (res.ok) applyActivity(await res.json());
      } catch {}
    }

    let stream = null;
    function setLivePolling(live) {
      window.clearInterval(poll);
      poll = 0;
      if (stream) { stream.close(); stream = null; }
      if (!live) return;
      if (typeof EventSource !== 'undefined') {
        // Server pushes activity on file changes; EventSource auto-reconnects on drop.
        stream = new EventSource('/api/activity-stream');
        stream.onmessage = event => { try { applyActivity(JSON.parse(event.data)); } catch {} };
      } else {
        poll = window.setInterval(() => { pollLive().catch(() => {}); }, 5000);
      }
    }

    document.addEventListener('dw:live-toggle', event => {
      setLivePolling(Boolean(event.detail?.live));
    });

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-preview]').forEach(node => {
        if (node instanceof HTMLElement && !node.hasAttribute('tabindex')) node.tabIndex = 0;
      });
      const doc = new URLSearchParams(location.search).get('doc');
      if (doc) {
        const match = document.querySelector(`[data-preview="${CSS.escape(doc)}"]`);
        if (match instanceof HTMLElement) openTarget(match);
        else if (details[doc]) select(doc, null);
      }
      setLivePolling(document.getElementById('app')?.hasAttribute('data-live'));
    });
  </script>
</MonitorLayout>
