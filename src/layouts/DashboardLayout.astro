---
const { title = 'docwatch' } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      body { font: 14px/1.5 system-ui, sans-serif; margin: 0; padding: 0 24px 32px; }
      main { max-width: 1200px; margin: 0 auto; }
      .banner { border: 1px solid #ddd; border-radius: 8px; padding: 12px; margin: 16px 0; }
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      @media (max-width: 800px) { .grid { grid-template-columns: 1fr; } }
      .col { border: 1px solid #eee; border-radius: 8px; padding: 12px; }
      h1 { font-size: 20px; margin: 16px 0 8px; }
      h2 { font-size: 14px; margin: 0 0 8px; color: #555; }
    </style>
  </head>
  <body><main><h1>docwatch</h1><slot /></main></body>
</html>
