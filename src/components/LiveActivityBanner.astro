---
import { getActivity, type Activity } from '@/data/activity';
import { DEFAULT_CONFIG } from '@/data/config';
import { targetRepoRoot } from '@/data/paths';
const initial: Activity = await getActivity(targetRepoRoot(), DEFAULT_CONFIG);
---
<div id="lab-root" data-initial={JSON.stringify(initial)}>
  <div class="card">
    <h2>Dirty files <span class="n">{initial.dirty.length}</span></h2>
    <ul id="lab-dirty"></ul>
  </div>
  <div class="card">
    <h2>Recently modified</h2>
    <ul id="lab-recent"></ul>
  </div>
  <div class="card">
    <h2>Active plan</h2>
    <div id="lab-plan"></div>
  </div>
</div>
<style>
  #lab-root { display: contents; }

  h2 {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  h2 .n {
    margin-left: auto;
    font-size: 11px;
    background: var(--chip);
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 1px 8px;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 7px 0;
    color: var(--muted);
    font-size: 12.5px;
  }

  li code {
    font-family: "SF Mono", ui-monospace, monospace;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 20px;
    background: rgba(9, 105, 218, .10);
    color: var(--blue);
  }

  #lab-plan {
    color: var(--muted);
    font-size: 13px;
  }
</style>
<script>
  const root = document.getElementById('lab-root');
  function esc(value) {
    return String(value ?? '').replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[ch]));
  }
  function render(d) {
    const q = (id) => document.getElementById(id);
    q('lab-dirty').innerHTML = (d.dirty || []).slice(0, 20)
      .map(x => `<li><code>${esc(x.status)}</code> ${esc(x.path)}</li>`).join('') || '<li style="color:#888">clean</li>';
    q('lab-recent').innerHTML = (d.recentlyModified || [])
      .map(x => `<li>${esc(x.path)}</li>`).join('') || '<li style="color:#888">none</li>';
    q('lab-plan').innerHTML = d.activePlan
      ? `<strong>Active plan:</strong> ${esc(d.activePlan.title)} <span style="color:#888">(${esc(d.activePlan.path)})</span>`
      : '<span style="color:#888">no active plan</span>';
  }
  render(JSON.parse(root?.dataset.initial || '{}'));
  setInterval(async () => {
    try { const r = await fetch('/api/activity.json', { cache: 'no-store' }); if (r.ok) render(await r.json()); } catch {}
  }, 5000);
</script>
